{
  "name": "pytest-dsl-support",
  "displayName": "pytest-DSL Support",
  "description": "VSCode extension for pytest-DSL language support with keyword completion and UI editor",
  "version": "0.3.0",
  "publisher": "felix-1991",
  "repository": {
    "type": "git",
    "url": "https://github.com/felix-1991/pytest-dsl-vscode-extension.git"
  },
  "bugs": {
    "url": "https://github.com/felix-1991/pytest-dsl-vscode-extension/issues"
  },
  "homepage": "https://github.com/felix-1991/pytest-dsl-vscode-extension#readme",
  "license": "MIT",
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "pytest",
    "dsl",
    "testing",
    "automation",
    "python",
    "test-framework",
    "language-support",
    "syntax-highlighting",
    "autocompletion"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:pytest-dsl",
    "onCommand:pytest-dsl.showKeywords",
    "onCommand:pytest-dsl.insertKeyword",
    "onCommand:pytest-dsl.editKeyword",
    "onCommand:pytest-dsl.refreshKeywords",
    "onCommand:pytest-dsl.generateKeywordsFile",
    "onCommand:pytest-dsl.searchKeywords",
    "onCommand:pytest-dsl.filterByCategory",
    "onCommand:pytest-dsl.insertKeywordWithParams",
    "onCommand:pytest-dsl.runFile",
    "onCommand:pytest-dsl.debugFile",
    "onCommand:pytest-dsl.debugFromCursor",
    "onCommand:pytest-dsl.selectConfig",
    "onCommand:pytest-dsl.runFileWithConfig",
    "onCommand:pytest-dsl.debugFileWithConfig",
    "onView:pytest-dsl-keywords"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pytest-dsl",
        "aliases": [
          "pytest-DSL",
          "dsl"
        ],
        "extensions": [
          ".dsl",
          ".auto",
          ".resource"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pytest-dsl",
        "scopeName": "source.pytest-dsl",
        "path": "./syntaxes/pytest-dsl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "pytest-dsl",
        "path": "./snippets/pytest-dsl.json"
      }
    ],
    "commands": [
      {
        "command": "pytest-dsl.showKeywords",
        "title": "显示关键字列表",
        "category": "pytest-DSL"
      },
      {
        "command": "pytest-dsl.insertKeyword",
        "title": "插入关键字",
        "category": "pytest-DSL"
      },
      {
        "command": "pytest-dsl.editKeyword",
        "title": "编辑关键字",
        "category": "pytest-DSL"
      },
      {
        "command": "pytest-dsl.refreshKeywords",
        "title": "刷新关键字缓存",
        "category": "pytest-DSL"
      },
      {
        "command": "pytest-dsl.generateKeywordsFile",
        "title": "生成关键字JSON文件",
        "category": "pytest-DSL"
      },
      {
        "command": "pytest-dsl.searchKeywords",
        "title": "智能搜索关键字",
        "category": "pytest-DSL",
        "icon": "$(search)"
      },
      {
        "command": "pytest-dsl.filterByCategory",
        "title": "按分类筛选",
        "category": "pytest-DSL",
        "icon": "$(filter)"
      },
      {
        "command": "pytest-dsl.insertKeywordWithParams",
        "title": "插入带参数模板的关键字",
        "category": "pytest-DSL",
        "icon": "$(add)"
      },
      {
        "command": "pytest-dsl.insertKeywordFromTree",
        "title": "插入关键字",
        "icon": "$(add)"
      },
      {
        "command": "pytest-dsl.previewKeyword",
        "title": "预览关键字",
        "icon": "$(eye)"
      },
      {
        "command": "pytest-dsl.toggleFavorite",
        "title": "切换收藏状态",
        "icon": "$(star)"
      },
      {
        "command": "pytest-dsl.runFile",
        "title": "运行当前文件",
        "category": "pytest-DSL",
        "icon": "$(run)"
      },
      {
        "command": "pytest-dsl.debugFile",
        "title": "调试当前文件",
        "category": "pytest-DSL",
        "icon": "$(debug-alt)"
      },
      {
        "command": "pytest-dsl.debugFromCursor",
        "title": "从当前行开始调试",
        "category": "pytest-DSL",
        "icon": "$(debug-start)"
      },
      {
        "command": "pytest-dsl.debugNext",
        "title": "调试：下一步",
        "category": "pytest-DSL",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "pytest-dsl.debugContinue",
        "title": "调试：继续",
        "category": "pytest-DSL",
        "icon": "$(debug-continue)"
      },
      {
        "command": "pytest-dsl.stopExecution",
        "title": "停止运行或调试",
        "category": "pytest-DSL",
        "icon": "$(debug-stop)"
      },
      {
        "command": "pytest-dsl.selectConfig",
        "title": "选择项目运行配置",
        "category": "pytest-DSL",
        "icon": "$(settings-gear)"
      },
      {
        "command": "pytest-dsl.refreshConfigs",
        "title": "刷新项目配置文件",
        "category": "pytest-DSL",
        "icon": "$(refresh)"
      },
      {
        "command": "pytest-dsl.manageConfigProfiles",
        "title": "管理配置方案",
        "category": "pytest-DSL",
        "icon": "$(symbol-enum)"
      },
      {
        "command": "pytest-dsl.runFileWithConfig",
        "title": "使用配置运行当前文件…",
        "category": "pytest-DSL",
        "icon": "$(run-all)"
      },
      {
        "command": "pytest-dsl.debugFileWithConfig",
        "title": "使用配置调试当前文件…",
        "category": "pytest-DSL",
        "icon": "$(debug-alt-small)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "pytest-dsl-keywords",
          "name": "pytest-DSL 关键字",
          "when": "workspaceHasTask:pytest-dsl || resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource'"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "pytest-dsl-keywords",
        "contents": "未找到 pytest-DSL 关键字。\n[生成关键字文件](command:pytest-dsl.generateKeywordsFile)\n[刷新](command:pytest-dsl.refreshKeywords)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pytest-dsl.searchKeywords",
          "when": "view == pytest-dsl-keywords",
          "group": "navigation@1"
        },
        {
          "command": "pytest-dsl.filterByCategory",
          "when": "view == pytest-dsl-keywords",
          "group": "navigation@2"
        },
        {
          "command": "pytest-dsl.refreshKeywords",
          "when": "view == pytest-dsl-keywords",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "pytest-dsl.insertKeywordFromTree",
          "when": "view == pytest-dsl-keywords && viewItem == keyword",
          "group": "inline@1"
        },
        {
          "command": "pytest-dsl.previewKeyword",
          "when": "view == pytest-dsl-keywords && viewItem == keyword",
          "group": "inline@2"
        },
        {
          "command": "pytest-dsl.toggleFavorite",
          "when": "view == pytest-dsl-keywords && viewItem == keyword",
          "group": "inline@3"
        },
        {
          "command": "pytest-dsl.insertKeywordFromTree",
          "when": "view == pytest-dsl-keywords && viewItem == keyword",
          "group": "actions@1"
        },
        {
          "command": "pytest-dsl.previewKeyword",
          "when": "view == pytest-dsl-keywords && viewItem == keyword",
          "group": "actions@2"
        },
        {
          "command": "pytest-dsl.editKeyword",
          "when": "view == pytest-dsl-keywords && viewItem == keyword",
          "group": "actions@3"
        },
        {
          "command": "pytest-dsl.toggleFavorite",
          "when": "view == pytest-dsl-keywords && viewItem == keyword",
          "group": "favorites@1"
        }
      ],
      "editor/context": [
        {
          "when": "editorLangId == pytest-dsl && (resourceExtname == '.dsl' || resourceExtname == '.auto') && !pytest-dsl.executionRunning",
          "command": "pytest-dsl.runFile",
          "group": "pytest-dsl@1"
        },
        {
          "when": "editorLangId == pytest-dsl && (resourceExtname == '.dsl' || resourceExtname == '.auto') && !pytest-dsl.executionRunning",
          "command": "pytest-dsl.runFileWithConfig",
          "group": "pytest-dsl@1.1"
        },
        {
          "when": "editorLangId == pytest-dsl && (resourceExtname == '.dsl' || resourceExtname == '.auto') && !pytest-dsl.executionRunning",
          "command": "pytest-dsl.debugFile",
          "group": "pytest-dsl@2"
        },
        {
          "when": "editorLangId == pytest-dsl && (resourceExtname == '.dsl' || resourceExtname == '.auto') && !pytest-dsl.executionRunning",
          "command": "pytest-dsl.debugFileWithConfig",
          "group": "pytest-dsl@2.1"
        },
        {
          "when": "editorLangId == pytest-dsl && (resourceExtname == '.dsl' || resourceExtname == '.auto') && !pytest-dsl.executionRunning",
          "command": "pytest-dsl.debugFromCursor",
          "group": "pytest-dsl@3"
        },
        {
          "when": "resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource'",
          "command": "pytest-dsl.showKeywords",
          "group": "pytest-dsl"
        },
        {
          "when": "resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource'",
          "command": "pytest-dsl.insertKeyword",
          "group": "pytest-dsl"
        },
        {
          "when": "resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource'",
          "command": "pytest-dsl.searchKeywords",
          "group": "pytest-dsl"
        },
        {
          "when": "resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource'",
          "command": "pytest-dsl.insertKeywordWithParams",
          "group": "pytest-dsl"
        }
      ],
      "editor/title/run": [
        {
          "when": "editorLangId == pytest-dsl && (resourceExtname == '.dsl' || resourceExtname == '.auto') && !pytest-dsl.executionRunning",
          "command": "pytest-dsl.runFile",
          "group": "navigation@1"
        },
        {
          "when": "editorLangId == pytest-dsl && (resourceExtname == '.dsl' || resourceExtname == '.auto') && !pytest-dsl.executionRunning",
          "command": "pytest-dsl.debugFile",
          "group": "navigation@2"
        },
        {
          "when": "editorLangId == pytest-dsl && pytest-dsl.executionRunning",
          "command": "pytest-dsl.stopExecution",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "pytest-dsl.showKeywords"
        },
        {
          "command": "pytest-dsl.insertKeyword"
        },
        {
          "command": "pytest-dsl.editKeyword"
        },
        {
          "command": "pytest-dsl.refreshKeywords"
        },
        {
          "command": "pytest-dsl.generateKeywordsFile"
        },
        {
          "command": "pytest-dsl.searchKeywords"
        },
        {
          "command": "pytest-dsl.filterByCategory"
        },
        {
          "command": "pytest-dsl.insertKeywordWithParams"
        },
        {
          "command": "pytest-dsl.insertKeywordFromTree",
          "when": "false"
        },
        {
          "command": "pytest-dsl.previewKeyword",
          "when": "false"
        },
        {
          "command": "pytest-dsl.toggleFavorite",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "pytest-dsl.showKeywords",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorTextFocus && (resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource')"
      },
      {
        "command": "pytest-dsl.insertKeyword",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus && (resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource')"
      },
      {
        "command": "pytest-dsl.searchKeywords",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus && (resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource')"
      },
      {
        "command": "pytest-dsl.insertKeywordWithParams",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorTextFocus && (resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource')"
      },
      {
        "command": "pytest-dsl.filterByCategory",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "editorTextFocus && (resourceExtname == '.dsl' || resourceExtname == '.auto' || resourceExtname == '.resource')"
      },
      {
        "command": "pytest-dsl.runFile",
        "key": "ctrl+f5",
        "mac": "ctrl+f5",
        "when": "editorTextFocus && editorLangId == pytest-dsl && !pytest-dsl.executionRunning"
      },
      {
        "command": "pytest-dsl.debugFile",
        "key": "f5",
        "when": "editorTextFocus && editorLangId == pytest-dsl && !pytest-dsl.executionRunning"
      },
      {
        "command": "pytest-dsl.debugFromCursor",
        "key": "alt+f5",
        "when": "editorTextFocus && editorLangId == pytest-dsl && !pytest-dsl.executionRunning"
      },
      {
        "command": "pytest-dsl.debugNext",
        "key": "f10",
        "when": "pytest-dsl.debugPaused"
      },
      {
        "command": "pytest-dsl.debugContinue",
        "key": "f5",
        "when": "pytest-dsl.debugPaused"
      },
      {
        "command": "pytest-dsl.stopExecution",
        "key": "shift+f5",
        "when": "pytest-dsl.executionRunning"
      }
    ],
    "configuration": {
      "title": "pytest-DSL",
      "properties": {
        "pytest-dsl.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python解释器路径（留空则优先使用项目 .venv/venv，再回退到系统 Python）"
        },
        "pytest-dsl.projectRoot": {
          "type": "string",
          "default": "",
          "description": "pytest-dsl项目根目录路径（留空则自动检测）"
        },
        "pytest-dsl.enableAutoCompletion": {
          "type": "boolean",
          "default": true,
          "description": "启用关键字自动补全"
        },
        "pytest-dsl.cacheTimeout": {
          "type": "number",
          "default": 300,
          "description": "关键字缓存超时时间（秒）"
        },
        "pytest-dsl.keywordsJsonPath": {
          "type": "string",
          "default": "",
          "description": "关键字JSON文件路径（相对于项目根目录，留空则自动查找）"
        },
        "pytest-dsl.remoteServerEnabled": {
          "type": "boolean",
          "default": true,
          "description": "启用远程服务器支持"
        },
        "pytest-dsl.yamlConfigSupport": {
          "type": "boolean",
          "default": true,
          "description": "启用YAML配置支持"
        },
        "pytest-dsl.autoImportRemoteServers": {
          "type": "boolean",
          "default": false,
          "description": "自动导入YAML文件中定义的远程服务器"
        },
        "pytest-dsl.treeViewAutoExpand": {
          "type": "boolean",
          "default": true,
          "description": "自动展开收藏夹分类"
        },
        "pytest-dsl.showParameterCount": {
          "type": "boolean",
          "default": true,
          "description": "在关键字列表中显示参数数量"
        },
        "pytest-dsl.enableSmartInsert": {
          "type": "boolean",
          "default": true,
          "description": "启用智能插入（自动生成参数模板）"
        },
        "pytest-dsl.maxSearchResults": {
          "type": "number",
          "default": 50,
          "description": "搜索结果的最大数量"
        },
        "pytest-dsl.yamlVars": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "运行和调试时传给 pytest-dsl 的 YAML 变量文件（相对于项目目录或绝对路径）"
        },
        "pytest-dsl.configProfiles": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": "可复用的有序配置方案；键为方案名，值为按加载顺序排列的 YAML 文件"
        },
        "pytest-dsl.activeConfigProfile": {
          "type": "string",
          "default": "",
          "description": "未在状态栏选择过配置时默认启用的配置方案名称"
        },
        "pytest-dsl.enableExecutionCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "在 DSL 文件中显示运行、调试和从当前步骤调试的 CodeLens"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:unit": "npm run compile && node --test test/*.test.js",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {}
}
